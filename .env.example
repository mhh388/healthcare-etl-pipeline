# ============================================================
# Healthcare ETL Pipeline — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to Git — it's in .gitignore

# ── AWS Configuration ────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=default                          # AWS CLI profile name

# ── S3 Data Lake ─────────────────────────────────────────────
S3_BUCKET=healthcare-etl-mengqi              # Your bucket name
S3_RAW_PREFIX=raw                            # s3://bucket/raw/
S3_PROCESSED_PREFIX=processed                # s3://bucket/processed/
S3_ATHENA_RESULTS=athena-results             # s3://bucket/athena-results/

# ── AWS Glue ─────────────────────────────────────────────────
GLUE_DATABASE=healthcare_db
GLUE_CRAWLER_NAME=healthcare_crawler

# ── AWS Athena ────────────────────────────────────────────────
ATHENA_DATABASE=healthcare_db
ATHENA_WORKGROUP=primary

# ── CMS Data Source ───────────────────────────────────────────
CMS_DATA_URL=https://data.cms.gov/provider-summary-by-type-of-service/medicare-part-d-prescribers/medicare-part-d-prescribers-by-provider-and-drug/data
CMS_DATASET_YEAR=2022

# ── Pipeline Settings ─────────────────────────────────────────
PIPELINE_ENV=development                     # development | production
LOG_LEVEL=INFO
CHUNK_SIZE=100000                            # Rows per processing chunk
